# Postgres com pgvector (imagem pgvector/pgvector:pg17)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/loregrid

# Segredo do JWT (troque em produção — use um valor aleatório longo)
JWT_SECRET=change-me-in-production

# Servidor
PORT=3000
HOST=0.0.0.0

# CORS: origem do frontend (Vite dev = http://localhost:5173)
CORS_ORIGIN=http://localhost:5173
